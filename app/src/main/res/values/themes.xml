<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Cash_Control" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#2E7D32</item>
        <item name="colorPrimaryVariant">#1B5E20</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">#1CF66B</item>
        <item name="colorSecondaryVariant">#14B850</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color - Setting this to match your green background -->
        <item name="android:statusBarColor">#2E7D32</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>
</resources>