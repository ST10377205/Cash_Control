<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2E7D32">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:layout_above="@+id/navBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_margin="16dp">

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Set Monthly Goals"
                android:textColor="#2E7D32"
                android:textSize="28sp"
                android:textStyle="bold"/>

            <!-- DESCRIPTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_gravity="center"
                android:text="Set your spending range for the month"
                android:textAlignment="center"
                android:textColor="#2E7D32"
                android:textSize="14sp"/>

            <!-- MIN GOAL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Minimum Spending Goal"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/inputMinGoal"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:hint="Min R 0.00"
                android:padding="12dp"
                android:background="#F3F4F6"
                android:inputType="numberDecimal"
                android:textColor="@color/black"/>

            <!-- MAX GOAL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Maximum Spending Goal"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/inputMaxGoal"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:hint="Max R 0.00"
                android:padding="12dp"
                android:background="#F3F4F6"
                android:inputType="numberDecimal"
                android:textColor="@color/black"/>

            <!-- PREVIEW CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#F9FAFB"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtGoalRange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Goal Range: R 0 - R 0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- SAVE BUTTON -->
            <Button
                android:id="@+id/btnSaveBudget"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="Save Goals"
                android:textSize="18sp"
                android:textStyle="bold"
                android:backgroundTint="#2E7D32"
                android:onClick="saveBudget"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FIXED NAVBAR AT BOTTOM -->
    <androidx.cardview.widget.CardView
        android:id="@+id/navBar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:src="@drawable/ic_home"
                android:onClick="openHome"
                app:tint="#2E7D32" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:src="@drawable/ic_history"
                android:onClick="openHistory"
                app:tint="#777777" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:src="@drawable/ic_stats"
                android:onClick="openStats"
                app:tint="#777777" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:src="@drawable/ic_profile"
                android:onClick="openProfile"
                app:tint="#777777" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</RelativeLayout>
